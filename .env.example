# Primary route: backend proxy endpoint (for hosted environments)
REACT_APP_AI_PROXY_URL=/api/ai.php

# Optional local fallback only (avoid using client-side keys in production)
REACT_APP_FREE_LLM_API_URL=https://apifreellm.com/api/v1/chat
REACT_APP_FREE_LLM_API_KEY=your_apifreellm_key_here

# Leave proxy enabled for localhost; set to true only if you want to skip the dev proxy
# REACT_APP_DISABLE_PROXY=false

